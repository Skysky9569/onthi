{
  "name": "design-system-automation",
  "version": "1.0.0",
  "description": "Automated design system based on toanck2.html with visual comparison and auto-fix capabilities",
  "main": "compare.js",
  "scripts": {
    "compare": "node compare.js",
    "notify": "node notify.js",
    "install-deps": "npm install",
    "setup": "npm install && mkdir -p screenshots output",
    "test": "node compare.js output.html",
    "web:server": "node api-server.js",
    "discord:bot": "node discord-claude-cli-bot.js"
  },
  "keywords": [
    "design-system",
    "visual-testing",
    "automation",
    "playwright",
    "pixelmatch"
  ],
  "author": "Design System Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "axios": "^1.15.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.40.0",
    "pngjs": "^7.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
